# ===========================================
# ENVIRONMENT
# ===========================================
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# ===========================================
# MONGODB
# ===========================================
MONGO_URI=mongodb://localhost:27017
MONGO_DB=irpf_processor

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# STORAGE
# ===========================================
STORAGE_TYPE=minio

# ===========================================
# MINIO (S3) - used when STORAGE_TYPE=minio
# ===========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

# ===========================================
# GCS (Google Cloud Storage) - used when STORAGE_TYPE=gcs
# ===========================================
GCP_BUCKET=irpf-documents
GCP_CREDENTIALS_PATH=
GCP_AUTH_TYPE=adc
GCP_EMULATOR_ENDPOINT=

# ===========================================
# OCR
# ===========================================
OCR_ENGINE=tesseract
# OCR_ENGINE=docling
# OCR_ENGINE=documentai
DOCUMENTAI_PROJECT_ID=
DOCUMENTAI_LOCATION=us
DOCUMENTAI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ===========================================
# API
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
CORRELATION_ID_HEADER=X-Correlation-ID

# ===========================================
# WORKERS
# ===========================================
DRAMATIQ_PROCESSES=2
DRAMATIQ_THREADS=4

# ===========================================
# EXTRACTION
# ===========================================
CONFIDENCE_THRESHOLD=0.6
MAX_RETRY_ATTEMPTS=3

# ===========================================
# LLM EXTRACTION — per-section toggles
# Set to true/false to enable/disable LLM for each section
# ===========================================
LLM_EXTRACTION_ASSETS_DECLARATION=true
# LLM_EXTRACTION_DEBTS_AND_ENCUMBRANCES=false
# LLM_EXTRACTION_DONATIONS_MADE=false
# LLM_EXTRACTION_PAYMENTS_MADE=false
# LLM_EXTRACTION_EXEMPT_INCOME=false
# LLM_EXTRACTION_EXCLUSIVE_TAXATION_INCOME=false
# LLM_EXTRACTION_INCOME_FROM_LEGAL_PERSON_TO_HOLDER=false
# LLM_EXTRACTION_INCOME_FROM_LEGAL_PERSON_TO_DEPENDENTS=false
# LLM_EXTRACTION_INCOME_FROM_INDIVIDUAL_TO_HOLDER=false
# LLM_EXTRACTION_INCOME_FROM_INDIVIDUAL_TO_DEPENDENTS=false

# LLM Provider
LLM_MAX_IMAGES_PER_CALL=5

# ===========================================
# USAGE
# ===========================================
# Copy this file to .env and adjust values:
# cp env.example .env
