# ===========================================
# ENVIRONMENT - GCS MODE (LOCAL EMULATOR)
# ===========================================
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# ===========================================
# MONGODB
# ===========================================
MONGO_URI=mongodb://localhost:27017
MONGO_DB=irpf_processor

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# STORAGE - Using GCS Emulator
# ===========================================
STORAGE_TYPE=gcs
GCP_BUCKET=irpf-documents
GCP_AUTH_TYPE=anonymous
GCP_EMULATOR_ENDPOINT=http://fake-gcs:4443

# ===========================================
# OCR
# ===========================================
OCR_ENGINE=tesseract
# OCR_ENGINE=documentai
DOCUMENTAI_PROJECT_ID=gcp-super-ia-hml
DOCUMENTAI_LOCATION=us
DOCUMENTAI_PROCESSOR_ID=5f3849577c733bdf
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/documentai-key.json

# ===========================================
# API
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
CORRELATION_ID_HEADER=X-Correlation-ID

# ===========================================
# WORKERS
# ===========================================
DRAMATIQ_PROCESSES=2
DRAMATIQ_THREADS=4

# ===========================================
# EXTRACTION
# ===========================================
CONFIDENCE_THRESHOLD=0.6
MAX_RETRY_ATTEMPTS=3

# ===========================================
# USAGE
# ===========================================
# To use GCS emulator locally:
# cp env.gcs.example .env
# docker compose up -d
